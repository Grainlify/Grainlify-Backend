DB_URL=
AUTO_MIGRATE=true

# Connection pool tuning (optional — defaults shown)
# DB_MAX_CONNS=10          # Maximum connections in the pool
# DB_MIN_CONNS=0           # Minimum idle connections kept open
# DB_MAX_CONN_LIFETIME=30m # Max time a connection may be reused (Go duration: 30m, 1h, …)
# DB_MAX_CONN_IDLE_TIME=5m # Max idle time before a connection is closed
JWT_SECRET='dev-secret-change-me'
ADMIN_BOOTSTRAP_TOKEN=                   # Must be at least 32 characters, only active when APP_ENV=dev
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=
GITHUB_LOGIN_REDIRECT_URL=http://grainlify-api.eba-b37kc6rt.us-west-2.elasticbeanstalk.com/auth/github/callback
GITHUB_OAUTH_REDIRECT_URL=http://grainlify-api.eba-b37kc6rt.us-west-2.elasticbeanstalk.com/auth/github/login/callback
GITHUB_OAUTH_SUCCESS_REDIRECT_URL=http://localhost:5173
TOKEN_ENC_KEY_B64=
GITHUB_WEBHOOK_SECRET=
GITHUB_LOGIN_SUCCESS_REDIRECT_URL=http://localhost:5173
DIDIT_WORKFLOW_ID=
DIDIT_API_KEY=
FRONTEND_BASE_URL=http://localhost:5173
# Comma-separated allowed CORS origins (production should list every trusted frontend)
# CORS_ORIGINS=https://grainlify.0xo.in,https://api.grainlify.0xo.in
# Allow *.vercel.app and *.0xo.in preview origins (off by default; see CORS_FIX.md)
# CORS_ALLOW_PREVIEW=false
GITHUB_APP_PRIVATE_KEY=
GITHUB_APP_ID=         # Your App ID (numeric)
GITHUB_APP_SLUG=     # Your App slug
GITHUB_WEBHOOK_SECRET=
PUBLIC_BASE_URL=http://grainlify-api.eba-b37kc6rt.us-west-2.elasticbeanstalk.com
# Maximum allowed size for request bodies in bytes (default: 1048576 / 1MB)
# Enforced on all routes except the GitHub webhook route which allows up to 10MB.
MAX_BODY_BYTES=1048576

# Optional Services
# NATS_URL is required when running the worker binary (APP_ROLE=worker).
# When set in the API process, the in-process syncjobs runner is disabled and
# the external worker is expected to handle background jobs instead.
NATS_URL=
# APP_ROLE selects which process this image runs:
#   api    — HTTP API server (cmd/api)    — default
#   worker — Background worker (cmd/worker) — requires NATS_URL + DB_URL
APP_ROLE=api
